{
    "name": "jo-81/blog",
    "description": "Framework PHP MVC sur mesure pour portfolio et blog",
    "type": "project",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "App\\": "src/",
            "Framework\\": "framework/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.1",
        "cycle/orm": "^2.18",
        "filp/whoops": "^2.18",
        "middlewares/access-log": "^2.2",
        "middlewares/debugbar": "^2.2",
        "middlewares/error-handler": "^3.1",
        "middlewares/trailing-slash": "^2.1",
        "middlewares/whoops": "^2.1",
        "monolog/monolog": "^3.10",
        "nikic/fast-route": "^1.3",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "php-di/php-di": "^7.1",
        "relay/relay": "^3.0",
        "twig/twig": "^3.27",
        "vlucas/phpdotenv": "^5.6"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "process-timeout": 0,
        "sort-packages": true
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "pestphp/pest": "^1.23",
        "phpstan/phpstan": "^2.2",
        "symfony/var-dumper": "^6.4"
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "XDEBUG_MODE=coverage pest --coverage-html coverage-report",
        "lint": "php-cs-fixer check --diff",
        "lint:fix": "php-cs-fixer fix",
        "check": "phpstan"
    }
}
