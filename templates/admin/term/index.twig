{% extends 'admin/base.twig' %}

    {% block page_title %}
        {% if current_page == 'tags' %} Liste des tags
        {% else %} Liste des catégories
        {% endif %}
    {% endblock %}

{% block content %}
    <div class="row g-4">
        {# Formulaire #}
        <div class="col-12 col-lg-4">
            <section class="card mb-4">
                <div class="card-body">
                    <h2 class="mb-4 h6">{{ form_title }}</h2>

                    <form 
                        {% for key, value in form.attr %}
                            {{ key ~ "=" ~ value }}
                        {% endfor %}
                    >
                        {{ form_row(form, 'name') }}

                        {% if current_page == 'tags' %}
                            {{ form_row(form, 'color') }}
                        {% endif %}

                        {% if current_page == 'categories' %}
                            {{ form_row(form, 'description') }}
                        {% endif %}

                        {{ csrf_token() }}

                        {% if term is null %}
                            <button class="btn btn-link w-100" type="submit"><i class="bi bi-plus me-1"></i> Ajouter</button>
                        {% else %}
                            <div class="d-flex gap-2">
                                <button class="col-8 btn btn-link" type="submit">
                                    <i class="bi bi-floppy me-1"></i> Enregistrer
                                </button>
                                <a href="{{ path('admin.term.list', {termName: current_page}) }}" class="btn border col-4">Annuler</a>
                            </div>
                        {% endif %}                        
                    </form>
                </div>
            </section>
        </div>
        {# Formulaire #}

        {# Liste des terms #}
        <div class="col-12 col-lg-8">
            <section class="card">
                <div class="card-body">
                    <h2 class="h6">
                        {% if current_page == 'tags' %}Tous les tags
                        {% else %} Toutes les catégories
                        {% endif %}
                        ( {{ pagination.totalItems }} )
                    </h2>

                    {% include "widgets/message/_flash.twig" with {'dismissible': true} %}

                    {% if terms is defined and terms is not empty %}
                        <div class="table-responsive my-4">
                            <table class="table mb-0">
                                <thead class="bg-primary opacity-50">
                                    <tr>
                                        <th class="text-uppercase text-md" scope="col">#</th>
                                        <th class="text-uppercase text-md" scope="col">Nom</th>
                                        <th class="text-uppercase text-md" scope="col">Slug</th>
                                        {% if current_page == 'tags' %}
                                            <th class="text-uppercase text-md" scope="col">Couleur</th>
                                        {% endif %}
                                        {% if current_page == 'categories' %}
                                            <th class="text-uppercase text-md" scope="col">Description</th>
                                        {% endif %}
                                        <th class="text-uppercase text-md" scope="col">Actions</th>
                                    </tr>
                                </thead>

                                <tbody>
                                    {% for term in terms %}
                                        <tr>
                                            <td>{{ loop.index + (pagination.currentPage - 1) * pagination.itemsPerPage }}</td>
                                            <td>{{ term.name }}</td>
                                            <td>{{ term.slug }}</td>
                                            {% if current_page == 'tags' %}
                                            <td>
                                                <div class="p-3 w-25 rounded-3" style="background-color: {{ term.color }}">
                                                </div>
                                            </td>
                                            {% endif %}

                                            {% if current_page == 'categories' %}
                                                <td>{{ term.description }}</td>
                                            {% endif %}

                                            <td>
                                                <div class="d-flex gap-1">
                                                    <a href="{{ path('admin.term.list', {termName: current_page, id: term.id}) }}" class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    <button
                                                        data-bs-toggle="modal" 
                                                        data-bs-target="#remove_modal" 
                                                        {# data-path="{{ path('admin.term.remove', {id: term.id}) }}" #}
                                                        class="btn btn-outline-danger btn-sm">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <span class="text-md text-muted">
                                {{ display_pagination_info(pagination, current_page == 'tags' ? 'tags' : 'catégories') }}
                            </span>
                            {{ render_pagination(pagination) }}
                        </div>

                    {% else %} <p class="mb-0">Auncun élément d'enregistré</p>

                    {% endif %}
                </div>
            </section>
        </div>
        {# Liste des terms #}
    </div>
{% endblock %}