{% extends 'admin/base.twig' %}

{% block page_title %}Liste des tags{% endblock %}

{% block content %}
    <div class="row g-4">
        <div class="col-lg-4">
            <section class="card mb-4">
                <div class="card-body">
                    <h2 class="mb-4 h6">Ajouter un tag</h2>

                    <form method="POST" class="needs-validation">
                        {{ form_row(form, 'name') }}

                        {{ form_row(form, 'slug') }}

                        {{ form_row(form, 'color') }}

                        {{ csrf_token() }}

                        <button class="btn btn-link w-100" type="submit"><i class="bi bi-plus"></i> Ajouter</button>
                    </form>
                </div>
            </section>
        </div>

        <div class="col-lg-8">
            <section class="card">
                <div class="card-body">
                    <h2 class="h6">Tous les tags ( {{ pagination.totalItems }} )</h2>
                
                    {% if tags is defined and tags is not empty %}
                        <div class="table-responsive my-4">
                            <table class="table mb-0">
                                <thead class="bg-primary opacity-50">
                                    <tr>
                                        <th class="text-uppercase text-md" scope="col">#</th>
                                        <th class="text-uppercase text-md" scope="col">Nom</th>
                                        <th class="text-uppercase text-md" scope="col">Slug</th>
                                        <th class="text-uppercase text-md" scope="col">Couleur</th>
                                        <th class="text-uppercase text-md" scope="col">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for tag in tags %}
                                        <tr>
                                            <td>{{ loop.index + (pagination.currentPage - 1) * pagination.itemsPerPage }}</td>
                                            <td>{{ tag.name }}</td>
                                            <td>{{ tag.slug }}</td>
                                            <td>
                                                <div class="p-3 w-25 rounded-3" style="background-color: {{ tag.color }}">
                                                </div>
                                            </td>
                                            <td>
                                                <div class="d-flex gap-1">
                                                    <button class="btn btn-outline-primary btn-sm">
                                                        <i class="bi bi-pencil"></i>
                                                    </button>
                                                    <button class="btn btn-outline-danger btn-sm">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                        {% else %} <p class="mb-0">Auncun tag d'ajouté.</p>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-md text-muted">
                            {{ display_pagination_info(pagination) }}
                        </span>
                        {{ render_pagination(pagination) }}
                    </div>
                </div>
            </section>
        </div>
    </div>
{% endblock %}