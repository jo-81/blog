{% import "widgets/form/partials/_forms.twig" as forms %}

<div class="mb-3">

    {{ forms.label(name, options.label) }}

    <div class="input-group">

        {% if options.icon %}
            <span class="input-group-text"><i class="bi bi-fonts"></i></span>
        {% endif %}

        <textarea 
            class="form-control" 
            id="{{ name }}"
            name="{{ name }}"
            {% if options.attr %}
                {% for key, value in options.attr %}
                    {{ key ~ "=" ~ value }}
                {% endfor %}
            {% endif %}
        >{% if value is defined and value is not null %}{{ value }}{% endif %}</textarea>

        {% if error %}
            <div class="invalid-feedback">{{ error }}</div>
        {% endif %}
    </div>

    {{ forms.help(options.help) }}
</div>